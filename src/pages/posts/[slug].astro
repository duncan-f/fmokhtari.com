---
import { Icon } from "astro-icon";
import { slugify, dateFormat } from "@/utils";
import { getEntryBySlug } from "astro:content";
import Badge from "@components/Badge.astro";
import Article from "@components/Article.astro";
import Layout from "@layouts/Layout.astro";
import Link from "@components/Link.astro";

const { slug } = Astro.params;
const entry = await getEntryBySlug('posts', slug);
const { title, description, date, author, draft, tags } = entry.data;
const { Content } = await entry.render();
---

<Layout {title} {description}>
  <div class="pt-20 text-center">
    <h1 class="relative font-bold font-rubik text-4xl md:text-5xl">
      {title}

      <span class="absolute inline-flex">
      { draft && (
        <Badge>DRAFT</Badge>
      )}
      </span>
    </h1>
    <div
      class="md:flex items-center justify-center my-4 gap-6 text-sm md:text-md"
    >
    <span class="inline-flex items-center">
      <Icon name="tabler:user" width="20" height="20" />
      <div class="ml-1">
        <Link href={`/author/${slugify(author.name)}`}>{author.name}</Link>
      </div>
    </span>
    <span class="inline-flex items-center">
      <Icon name="tabler:calendar" width="20" height="20" />
      <div class="ml-1">{dateFormat(date)}</div>
    </span>
    <span class="inline-flex items-center">
      <Icon name="tabler:tags" width="20" height="20" />
      {tags.map((tag: any) =>
        <div class="inline-flex ml-2">#{tag}</div>
      )}
    </span>
    </div>
  </div>

  <Article className="prose dark:prose-invert prose-headings:font-rubik prose-p:text-justify prose-a:underline-offset-2 hover:prose-a:text-orange-500 prose-a:decoration-orange-500 prose-img:border prose-img:border-slate-300 dark:prose-img:border-zinc-700 prose-img:rounded-xl">
    <Content />
  </Article>
</Layout>
