---
import Body from "@/components/Body.astro";
import Head from "@/components/Head.astro";
import { Icon } from "astro-icon";
import { SITE_AUTHOR, SITE_DESCRIPTION } from "@/config";
---

<!DOCTYPE html>
<html lang="en">
<Head
  title="404 - Not found"
  author={SITE_AUTHOR}
  description={SITE_DESCRIPTION}
/>
<Body>
<div class="flex items-center h-screen px-5 py-2">
  <div class="flex-col justify-items-center text-center m-auto">
    <div class="flex items-center text-4xl font-bold text-center">
      <div class="text-orange-400 px-3">404</div>

      <span class="h-10 p-0.5 bg-slate-300"></span>

      <div class="px-3">Page not Found</div>
    </div>

    <div class="text-center py-2">
      Please check the URL in the address bar and try again.
    </div>

    <div class="w-44 py-6 m-auto">
      <a href="/">
        <div
          class="flex justify-between items-center rounded font-bold py-2 px-5 text-white bg-orange-600 hover:bg-orange-900"
        >
          <Icon name="tabler:chevron-left" width="24" height="24" />
          Go back home
        </div>
      </a>
    </div>
  </div>
</div>
</Body>
</html>

