---
import { Icon } from "astro-icon";
import { getEntryBySlug } from "astro:content";
import Header from "../../components/Header.astro";
import Article from "../../components/Article.astro";
import Layout from "../../layouts/Layout.astro";
import Link from "../../components/Link.astro";
import { Image } from "@astrojs/image/components";
import Badge from "../../components/Badge.astro";

const { slug } = Astro.params;
const entry = await getEntryBySlug('projects', slug);
const { Content } = await entry.render();
const { title, description, date, website, stack, image } = entry.data;
---

<Layout {title} {description}>
  <Header className="text-center">
    <h1 class="font-bold font-rubik text-2xl md:text-5xl text-center">
      {title}
      <Badge>{date}</Badge>
    </h1>
    <div class="md:flex md:items-center md:justify-center my-4 gap-6">
    <span class="inline-flex items-center">
      <Icon name="tabler:world" class="mb-1" width="20" height="20" />
      <div class="ml-1">
        <Link href={website}>{website}</Link>
      </div>
    </span>
    <span class="inline-flex items-center">
      <Icon name="tabler:stack" class="mb-1" width="20" height="20" />
      {stack.join(', ')}
    </span>
    </div>
  </Header>

  <Article className="prose dark:prose-invert prose-headings:font-rubik prose-a:underline-offset-2 hover:prose-a:text-emerald-500 prose-a:decoration-emerald-500 prose-img:border prose-img:border-slate-300 dark:prose-img:border-zinc-700 prose-img:rounded-xl">
    <Content />
  </Article>
  <div class="px-5">
  <Image
    src={image}
    alt={title}
    width={600}
    height={300}
    class="mx-auto rounded-xl border border-gray-500 dark:border-gray-50"
  />
  </div>
</Layout>

