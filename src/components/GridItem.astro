---
import { Image } from "@astrojs/image/components";

export interface Props {
  src: string;
  title: string;
}

const { src, title } = Astro.props as Props;
---

<div class="w-full">
  <Image
    {src}
    alt={title}
    width={400}
    height={300}
    class="border-1 border-slate-500 rounded-lg"
  />

  <div class="text-center">
    <h4 class="text-lg">{title}</h4>
    <p><slot /></p>
  </div>
</div>

