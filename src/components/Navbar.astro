---
import { SITE_NAME } from "../config";
import Brand from "./Brand.astro";
import NavbarLink from "./NavbarLink.astro";
import ThemeToggle from "./ThemeToggle";
import Hamburger from "./Hamburger";

---

<nav class="flex items-center justify-between mx-auto max-w-3xl px-10">
  <Brand>{SITE_NAME}</Brand>
  <ul class="hidden md:flex items-center justify-center gap-6">
    <NavbarLink href="/projects">Projects</NavbarLink>
    <NavbarLink href="/posts">Blog</NavbarLink>
  </ul>
  <ThemeToggle client:visible />
  <Hamburger client:visible />
</nav>
