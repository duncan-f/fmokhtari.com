---
import Body from '../components/Body.astro';
import Content from '../components/Content.astro';
import Footer from '../components/Footer.astro';
import Head from '../components/Head.astro';
import Header from '../components/Header.astro';
import Navbar from '../components/Navbar.astro';

const { frontmatter } = Astro.props;
const { title, description } = frontmatter;
---
<html lang="en">
  <Head {title} {description} />
	<Body>
    <Header>
      <Navbar />
    </Header>

    <Content className="prose dark:prose-invert prose-headings:font-rubik prose-a:underline-offset-2 hover:prose-a:text-emerald-500 prose-a:decoration-emerald-500 prose-img:border prose-img:border-slate-300 dark:prose-img:border-zinc-700 prose-img:rounded-xl">
		  <slot />
    </Content>

    <Footer />
	</Body>
</html>


